# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional: model override (default: claude-sonnet-4-6-20250514)
# CLAUDE_MODEL=claude-sonnet-4-6-20250514

# Optional: Firecrawl for URL scraping (secondary path)
# FIRECRAWL_API_KEY=fc-...

# Optional: data directory (default: data)
# DATA_DIR=data

# Optional: ChromaDB directory (default: data/chroma)
# CHROMA_DIR=data/chroma
